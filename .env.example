# Required — OpenAI API key for chat, embeddings, and fine-tuning.
OPENAI_API_KEY=sk-...

# Optional — fine-tuned Booking Advisor model id from tests/finetune_booking_advisor.ipynb.
# When unset, the Booking Advisor falls back to the base LLM used by the Trip Agent.
BOOKING_ADVISOR_MODEL=ft:gpt-4o-mini-...
